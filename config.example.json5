  //   anonymizeKey: "${PIOTR_ANONYMIZE_KEY}",
  // },

  // ai: {
  //   // Example substituting the value injected in the env block above
  //   gcpProjectId: "${PIOTR_GCP_PROJECT_ID}",
  //
  //   // The primary region for Vertex AI endpoints
  //   gcpLocation: "us-central1",
