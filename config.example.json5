  //   vars: {
  //     // IMPORTANT: It's recommended to set PIOTR_PROFILE_ENCRYPTION_KEY and PIOTR_ANONYMIZE_KEY 
  //     // in your actual system environment instead of here to prevent checking secrets into Git.
  //     //
  //     // Example setting a GCP project ID to be substituted later:
  //     PIOTR_GCP_PROJECT_ID: "your-gcp-project-id"
  //   }
  // },

  // database: {
  //   url: "sqlite://data/piotr.db",
  // },

  // security: {
  //   // Substitute from environment: Generate 32-byte hex strings via `openssl rand -hex 32`
